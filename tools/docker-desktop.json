{
  "id": "docker-desktop",
  "name": "Docker Desktop",
  "version": "4.36.0",
  "category": "infra",
  "description": "Container runtime required by Docker-based tools like CVAT, ROS 2, and Isaac Sim.",
  "icon": "docker.svg",
  "tags": ["container", "docker", "runtime", "infrastructure"],
  "install_type": "manual",
  "install_cmd": "",
  "install_url": "https://www.docker.com/products/docker-desktop/",
  "install_cmd_linux": "apt install -y docker.io",
  "install_cmd_win": "winget install -e --id Docker.DockerDesktop",
  "version_check_cmd": "docker --version",
  "launch_type": "url",
  "open_url": "https://www.docker.com/products/docker-desktop/",
  "launch_cmd": "",
  "health_check": { "type": "process", "target": "docker", "interval_ms": 10000 },
  "docs_url": "https://docs.docker.com/desktop/",
  "github_url": "https://github.com/docker/docker-install"
}
