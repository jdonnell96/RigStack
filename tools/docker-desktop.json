{
  "id": "docker-desktop",
  "name": "Docker Desktop",
  "version": "4.36.0",
  "category": "infra",
  "description": "Container runtime required by Docker-based tools in this catalog",
  "icon": "docker.svg",
  "tags": ["container", "docker", "runtime", "infrastructure"],
  "install_type": "script",
  "install_cmd": "pip install docker",
  "version_check_cmd": "docker --version",
  "launch_type": "process",
  "launch_cmd": "docker info",
  "health_check": { "type": "process", "target": "docker", "interval_ms": 10000 },
  "docs_url": "https://docs.docker.com/desktop/",
  "github_url": "https://github.com/docker/docker-install"
}
