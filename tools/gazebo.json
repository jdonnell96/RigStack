{
  "id": "gazebo",
  "name": "Gazebo",
  "version": "8.7.0",
  "category": "simulate",
  "description": "Open source 3D robotics simulator with physics engine",
  "icon": "gazebo.svg",
  "tags": ["simulation", "physics", "ros", "robotics", "3d"],
  "install_type": "apt",
  "install_cmd": "pip install gz-sim",
  "install_cmd_linux": "apt install gz-harmonic",
  "version_check_cmd": "gz sim --version",
  "launch_type": "process",
  "launch_cmd": "gz sim",
  "stop_cmd": "pkill -f gz",
  "stop_cmd_win": "taskkill /F /IM gz.exe",
  "health_check": { "type": "process", "target": "gz", "interval_ms": 5000 },
  "docs_url": "https://gazebosim.org/docs",
  "github_url": "https://github.com/gazebosim/gz-sim",
  "supported_os": ["linux", "macos"]
}
